{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VPScope",
  "version": "0.1.0",
  "identifier": "com.vpscope.app",
  "build": {
    "beforeDevCommand": "pnpm --dir web dev",
    "beforeBuildCommand": "pnpm --dir web build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "VPScope",
        "width": 1440,
        "height": 900,
        "minWidth": 1280,
        "minHeight": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
